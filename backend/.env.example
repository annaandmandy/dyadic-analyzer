# Dyadic Visual Social Signal Analyzer - Environment Variables

# OpenAI API key for LLM interpretation (optional - falls back to rule-based)
DYADIC_OPENAI_API_KEY=sk-your-key-here
DYADIC_OPENAI_MODEL=gpt-4o

# ElevenLabs API key for TTS voice simulation (optional)
DYADIC_ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Face detection backend: "mediapipe" or "retinaface"
DYADIC_FACE_DETECTION_BACKEND=mediapipe

# MiDaS model: "MiDaS_small" or "DPT_Large"
DYADIC_MIDAS_MODEL_TYPE=MiDaS_small

# Server settings
DYADIC_HOST=0.0.0.0
DYADIC_PORT=8000
DYADIC_DEBUG=false
